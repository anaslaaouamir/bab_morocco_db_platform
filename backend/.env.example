# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bab_morocco

# ── IA — Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# IMPORTANT: Claude is only activated when BOTH conditions are true:
#   1. ANTHROPIC_API_KEY is set (non-empty)
#   2. ENV=production
# In development (ENV=development), all AI calls use mock generators — no API charges.

# ── App ───────────────────────────────────────────────────────────────────────
# ENV controls mock vs production mode for all external services (AI, email).
# Values: development | production
ENV=development
SECRET_KEY=changeme
APP_VERSION=1.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing uses SECRET_KEY above. Tokens expire after JWT_EXPIRE_MINUTES.
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
# On startup, if the users table is empty and both vars below are set,
# the first Admin account is created automatically from these credentials.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Scraping (Phase 2 — not used in Phase 1) ──────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Email (Phase 2 — mock in Phase 1, Mailgun in Phase 2) ────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
